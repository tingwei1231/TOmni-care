# TOmni-Care Agent — 環境變數設定範本
# 複製此檔案為 .env 並填入實際值

# ─── ASR 設定 ───────────────────────────────────
# Faster-Whisper 模型大小（tiny/base/small/medium/large-v3）
# Colab T4：推薦 medium（~5GB VRAM）
# 生產伺服器：large-v3（最高精度）
ASR_MODEL_SIZE=medium
# Fine-tuned 台語模型路徑（空值 = 使用官方 Whisper）
ASR_CUSTOM_MODEL_PATH=

# ─── TTS 設定 ───────────────────────────────────
# Bert-VITS2 模型目錄（空值 = gTTS fallback）
TTS_MODEL_PATH=
# 說話人 ID（多說話人模型）
TTS_SPEAKER_ID=0
# 語速（0.5~2.0，1.0=正常，長者建議 0.85）
TTS_SPEED=0.85

# ─── 裝置設定 ────────────────────────────────────
# "auto" 自動偵測，"cuda"，"cpu"
DEVICE=auto

# ─── Gradio Demo 設定 ────────────────────────────
# 伺服器埠號
GRADIO_PORT=7860
# 公開分享（Colab 使用）
GRADIO_SHARE=false

# ─── 第二階段：LLM 設定（預留）────────────────────
# Groq API 金鑰（https://console.groq.com）
GROQ_API_KEY=
# OpenRouter API 金鑰
OPENROUTER_API_KEY=
# 使用的模型 ID
LLM_MODEL=meta-llama/llama-3-70b-instruct
